  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "VR LAB SAFETY TRAINING\n\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n\nCONTROLS:\n-
    Left Joystick - Move forward/backward/strafe\n- Right Joystick - Turn left/right\n-
    Grip Button - Grab objects\n- Trigger Button - Activate/Spray\n- Menu Button
    - Return to main menu\n\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n\nTRAINING
    SCENARIOS:\n\n1. Personal Protective Equipment\n   Grab and wear: lab coat, goggles,
    gloves\n   Score: 40 points\n\n2. Fire Extinguisher Safety\n   Grab extinguisher
    and spray fire\n   Use proper PASS technique\n   Score: 50 points\n\n3. Hazard
    Symbol Recognition\n   Identify 5 hazardous chemicals\n   Grab the correct bottles\n  
    Score: 70 points\n\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n\nTOTAL
    POSSIBLE SCORE: 160 Points\n\nComplete all scenarios for certification!\""
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
